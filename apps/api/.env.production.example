# Vertxing API — PRODUCTION environment (set these in your host's dashboard,
# e.g. Render → Environment. Do NOT commit real values.)

NODE_ENV=production
# Most hosts inject PORT automatically; the app honours it. Leave unset on Render.
# PORT=4000

# Comma-separated list of allowed web origins (your Vercel URL + any custom domain)
CORS_ORIGINS=https://your-app.vercel.app

# ── Postgres (Neon) — use the POOLED connection string, sslmode=require ──
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/vertxing?sslmode=require

# ── Redis (Upstash) — the rediss:// (TLS) URL ──
REDIS_URL=rediss://default:PASSWORD@xxxx.upstash.io:6379

# ── Auth secrets (generate strong random values) ──
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_ACCESS_SECRET=replace-with-strong-random
JWT_REFRESH_SECRET=replace-with-strong-random
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600

# ── LiveKit Cloud (media) — from your LiveKit Cloud project ──
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxx
LIVEKIT_API_SECRET=replace-with-livekit-secret

# ── Licensing ──
LICENSE_SECRET=replace-with-strong-random
# Optional: the email granted SUPER_ADMIN on first registration.
# SUPER_ADMIN_EMAIL=you@example.com

# ── Web Push / VAPID (background calls). Generate a fresh pair for production:
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@vertxing.app
