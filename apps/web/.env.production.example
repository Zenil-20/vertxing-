# Vertxing Web — PRODUCTION environment (set in Vercel → Project → Settings →
# Environment Variables, for the Production environment).
#
# IMPORTANT: NEXT_PUBLIC_* values are baked in at BUILD time, so set this BEFORE
# the build and redeploy if it changes. It is the public URL of your deployed
# API — used for both REST and the Socket.IO connection (the LiveKit media URL
# comes from the API, so it is NOT needed here).

NEXT_PUBLIC_API_URL=https://vertxing-api.onrender.com
