<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0C16">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/caller_avatar"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:background="@drawable/avatar_circle"
            android:gravity="center"
            android:text="?"
            android:textColor="#FFFFFF"
            android:textSize="48sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/caller_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Caller"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/call_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Incoming call"
            android:textColor="#9AA3BD"
            android:textSize="16sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="72dp"
        android:gravity="center"
        android:orientation="horizontal">

        <Button
            android:id="@+id/decline_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="36dp"
            android:background="#FF4D4F"
            android:paddingLeft="36dp"
            android:paddingTop="16dp"
            android:paddingRight="36dp"
            android:paddingBottom="16dp"
            android:text="Decline"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/accept_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="36dp"
            android:background="#34E0A8"
            android:paddingLeft="36dp"
            android:paddingTop="16dp"
            android:paddingRight="36dp"
            android:paddingBottom="16dp"
            android:text="Answer"
            android:textColor="#06281E" />
    </LinearLayout>
</RelativeLayout>
