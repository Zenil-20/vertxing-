# Vertxing — Real-Time Video Meeting Platform
# ─────────────────────────────────────────────────────────────────────────────
# File:    .env.example
# Purpose: Template for environment configuration. Copy to `.env` and fill in.
#          NEVER commit the real `.env`. All API config is validated at boot
#          (see apps/api/src/config/env.validation.ts) — the app refuses to
#          start with a missing/invalid value.
# ─────────────────────────────────────────────────────────────────────────────

# ── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=4000
# Comma-separated list of allowed browser origins for CORS.
CORS_ORIGINS=http://localhost:3000

# ── PostgreSQL (primary datastore) ───────────────────────────────────────────
DATABASE_URL=postgresql://vertxing:vertxing@localhost:5432/vertxing?schema=public

# ── Redis (presence, sessions, pub/sub) ──────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT auth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=MindTheGapChangeMeAccessSecret
JWT_REFRESH_SECRET=MindTheGapChangeMeRefreshSecret
JWT_ACCESS_TTL=900            # 15 minutes (seconds)
JWT_REFRESH_TTL=1209600      # 14 days (seconds)

# ── LiveKit (SFU / media engine) ─────────────────────────────────────────────
# Local dev keys match docker-compose.yml. Rotate for any real deployment.
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret-please-change-me-32chars

# ── Licensing ────────────────────────────────────────────────────────────────
# HS256 secret used to sign/verify license keys. Rotate for production.
LICENSE_SECRET=dev-only-license-secret-change-me-please-32chars
# Optional: the email granted SUPER_ADMIN on registration (operator-controlled).
# If unset, the FIRST account to register becomes the super-admin (bootstrap).
# SUPER_ADMIN_EMAIL=owner@yourcompany.com

# ── Web app ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_LIVEKIT_URL=ws://localhost:7880

# ── Web Push (VAPID) — background call notifications. Generate with:
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
# Leave blank to disable background push.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@vertxing.dev
